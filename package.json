{
  "name": "change-life-os",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:pages": "vite --config vite.pages.config.ts",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:pages": "vite build --config vite.pages.config.ts",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "vitest run --config vitest.config.ts && npm run test:payments && npm run typecheck:payments && npm run build:payments && npm run build && node --test tests/rendered-html.test.mjs",
    "test:google": "node --test tests/google-*.test.mjs",
    "test:pages": "npm run typecheck:client-core && vitest run --config vitest.config.ts && node --test tests/pages-contract.test.mjs && npm run build:pages",
    "test:payments": "vitest run --config vitest.payments.config.ts",
    "typecheck:payments": "tsc -p tsconfig.payments.json",
    "build:payments": "wrangler deploy --dry-run --config payments-worker/wrangler.toml",
    "dev:payments": "wrangler dev --config payments-worker/wrangler.toml",
    "db:migrate:payments:local": "wrangler d1 migrations apply change-life-os-payments --local --config payments-worker/wrangler.toml",
    "typecheck:client-core": "tsc -p tsconfig.client-core.json",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern dist-pages --ignore-pattern .next",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^3.2.4",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
